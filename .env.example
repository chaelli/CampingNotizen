# Supabase-Verbindung für den GETEILTEN Modus.
# Ohne diese Werte läuft die App im lokalen Modus (Daten nur auf diesem Gerät).
#
# Werte findest du im Supabase-Dashboard unter:
#   Project Settings -> API
#
# Diese Datei nach .env kopieren und ausfüllen:
#   cp .env.example .env

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
